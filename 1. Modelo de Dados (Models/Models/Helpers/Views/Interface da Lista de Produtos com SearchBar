<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProdutos"
             Title="Meus Produtos">

    <VerticalStackLayout Padding="10" Spacing="10">
        
        <SearchBar x:Name="txt_busca" 
                   Placeholder="Digite para buscar" 
                   TextChanged="OnSearchTextChanged" />

        <ListView x:Name="lst_produtos" HasUnevenRows="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextCell Text="{Binding Descricao}" 
                              Detail="{Binding Preco, StringFormat='R$ {0:F2}'}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button Text="Novo Produto" 
                Clicked="Button_Clicked" 
                BackgroundColor="#2196F3" />
    </VerticalStackLayout>
</ContentPage>
